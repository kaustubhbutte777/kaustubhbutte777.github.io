---
import BaseLayout from '../layouts/BaseLayout.astro';
import WavyGradient from '../components/ui/WavyGradient';
---

<BaseLayout title="Projects | Kaustubh Butte" description="Showcase of my software engineering projects">
  <WavyGradient client:load />
  <section class="py-20 px-4">
    <div class="max-w-6xl mx-auto">
      <div class="text-center mb-16">
        <h1 class="text-4xl md:text-5xl font-bold mb-4">
          <span class="gradient-text-animated">Projects</span>
        </h1>
        <p class="text-[var(--text-secondary)] text-lg max-w-2xl mx-auto">
          A collection of things I've built and worked on
        </p>
      </div>

      <div class="flex flex-col items-center justify-center py-16">
        <div class="glass-strong rounded-3xl p-12 md:p-16 text-center max-w-lg">
          <div class="text-6xl mb-6">🚧</div>
          <h2 class="text-2xl md:text-3xl font-bold text-[var(--text-primary)] mb-4">
            Still Compiling...
          </h2>
          <p class="text-[var(--text-secondary)] text-lg leading-relaxed mb-2">
            My projects are in the build pipeline.
          </p>
          <p class="text-[var(--text-muted)] text-sm">
            No segfaults so far — check back soon.
          </p>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
