---
import BaseLayout from '../layouts/BaseLayout.astro';
import WavyGradient from '../components/ui/WavyGradient';
import InterestsGallery from '../components/about/InterestsGallery';
---

<BaseLayout title="Beyond Code | Kaustubh Butte" description="Exploring life beyond the keyboard - hobbies, interests, and passions">
  <WavyGradient client:load />

  <section class="py-20 px-4">
    <div class="max-w-6xl mx-auto">
      <!-- Header -->
      <div class="text-center mb-16">
        <span class="inline-block px-4 py-1.5 rounded-full glass text-sm text-[var(--text-muted)] mb-6">
          Life Outside Work
        </span>
        <h1 class="text-5xl md:text-6xl font-bold mb-6">
          <span class="gradient-text-animated">Beyond Code</span>
        </h1>
        <p class="text-[var(--text-secondary)] text-lg md:text-xl max-w-2xl mx-auto leading-relaxed">
          When I'm not writing code or thinking about distributed systems,
          you'll find me exploring these interests and passions.
        </p>
      </div>

      <!-- Interests Gallery -->
      <InterestsGallery client:visible />

      <!-- Additional Content -->
      <div class="mt-20 grid md:grid-cols-2 gap-8">
        <div class="glass rounded-2xl p-8">
          <h2 class="text-2xl font-bold text-[var(--text-primary)] mb-4">Currently Reading</h2>
          <div class="space-y-4">
            <div class="flex items-start gap-4">
              <div class="w-12 h-16 bg-zinc-700/50 rounded flex items-center justify-center text-xs text-[var(--text-muted)]">
                Book
              </div>
              <div>
                <p class="font-medium text-[var(--text-primary)]">Designing Data-Intensive Applications</p>
                <p class="text-sm text-[var(--text-secondary)]">Martin Kleppmann</p>
              </div>
            </div>
            <div class="flex items-start gap-4">
              <div class="w-12 h-16 bg-zinc-700/50 rounded flex items-center justify-center text-xs text-[var(--text-muted)]">
                Book
              </div>
              <div>
                <p class="font-medium text-[var(--text-primary)]">System Design Interview</p>
                <p class="text-sm text-[var(--text-secondary)]">Alex Xu</p>
              </div>
            </div>
          </div>
        </div>

        <div class="glass rounded-2xl p-8">
          <h2 class="text-2xl font-bold text-[var(--text-primary)] mb-4">Currently Learning</h2>
          <div class="space-y-3">
            <div class="flex items-center gap-3">
              <div class="w-2 h-2 rounded-full bg-emerald-500"></div>
              <span class="text-[var(--text-secondary)]">Rust for systems programming</span>
            </div>
            <div class="flex items-center gap-3">
              <div class="w-2 h-2 rounded-full bg-blue-500"></div>
              <span class="text-[var(--text-secondary)]">Advanced Kubernetes patterns</span>
            </div>
            <div class="flex items-center gap-3">
              <div class="w-2 h-2 rounded-full bg-purple-500"></div>
              <span class="text-[var(--text-secondary)]">Database internals</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
