---
import BaseLayout from '../layouts/BaseLayout.astro';
import WavyGradient from '../components/ui/WavyGradient';
---

<BaseLayout title="Beyond Code | Kaustubh Butte" description="Exploring life beyond the keyboard - hobbies, interests, and passions">
  <WavyGradient client:load />

  <section class="py-20 px-4">
    <div class="max-w-6xl mx-auto">
      <div class="flex flex-col items-center justify-center py-16">
        <div class="glass-strong rounded-3xl p-12 md:p-16 text-center max-w-lg">
          <div class="text-6xl mb-6">~</div>
          <h1 class="text-3xl md:text-4xl font-bold mb-4">
            <span class="gradient-text-animated">Beyond Code</span>
          </h1>
          <p class="text-[var(--text-secondary)] text-lg leading-relaxed mb-2">
            This page is still in <code class="px-1.5 py-0.5 rounded bg-zinc-800 text-sm text-amber-400">development</code> mode.
          </p>
          <p class="text-[var(--text-muted)] text-sm italic">
            Turns out, documenting hobbies is harder than documenting APIs.
          </p>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
