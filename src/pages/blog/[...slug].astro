---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import TableOfContents from '../../components/blog/TableOfContents';
import ShareButtons from '../../components/blog/ShareButtons';
import LikeButton from '../../components/ui/LikeButton';
import ViewCounter from '../../components/ui/ViewCounter';
import WavyGradient from '../../components/ui/WavyGradient';

const allPosts = await getCollection('blog', ({ data }) => import.meta.env.DEV || data.draft !== true);
const sortedPosts = allPosts.sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => import.meta.env.DEV || data.draft !== true);
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content, headings } = await post.render();

// Calculate reading time if not provided
const wordCount = post.body?.split(/\s+/).length || 0;
const readingTime = post.data.readTime || `${Math.ceil(wordCount / 200)} min read`;

// Get current URL for sharing
const url = Astro.url.href;

// Previous / Next posts
const currentIndex = sortedPosts.findIndex(p => p.id === post.id);
const prevPost = currentIndex < sortedPosts.length - 1 ? sortedPosts[currentIndex + 1] : null;
const nextPost = currentIndex > 0 ? sortedPosts[currentIndex - 1] : null;
---

<BaseLayout title={`${post.data.title} | Blog`} description={post.data.description}>
  <WavyGradient client:load />
  <article class="py-12 px-4">
    <div class="max-w-6xl mx-auto">
      <div class="lg:flex lg:gap-8">
        <!-- Main Content -->
        <div class="flex-1 max-w-3xl">
          <!-- Header -->
          <header class="mb-12">
            <a href="/blog" class="text-zinc-500 hover:text-zinc-300 text-sm inline-flex items-center gap-2 mb-6">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
              </svg>
              Back to Blog
            </a>

            <!-- Tags -->
            {post.data.tags && post.data.tags.length > 0 && (
              <div class="flex flex-wrap items-center gap-2 mb-4">
                {post.data.tags.map((tag: string) => (
                  <a
                    href={`/blog/tags/${tag.toLowerCase().replace(/\s+/g, '-')}`}
                    class="px-3 py-1 rounded-full bg-emerald-500/20 text-emerald-400 text-sm hover:bg-emerald-500/30 transition-colors"
                  >
                    #{tag}
                  </a>
                ))}
              </div>
            )}

            <h1 class="text-4xl md:text-5xl font-bold text-[var(--text-primary)] mb-4">
              {post.data.title}
            </h1>

            <p class="text-xl text-[var(--text-secondary)] mb-6">
              {post.data.description}
            </p>

            <div class="flex flex-wrap items-center gap-4 text-sm text-[var(--text-muted)] pb-6 border-b border-zinc-700/50">
              <div class="flex items-center gap-2">
                <div class="w-8 h-8 rounded-full bg-zinc-700 flex items-center justify-center text-xs font-bold">
                  KB
                </div>
                <span>{post.data.author || 'Kaustubh Butte'}</span>
              </div>
              <span>·</span>
              <time datetime={post.data.date.toISOString()}>
                {new Date(post.data.date).toLocaleDateString('en-US', {
                  year: 'numeric',
                  month: 'long',
                  day: 'numeric'
                })}
              </time>
              <span>·</span>
              <span class="flex items-center gap-1">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
                {readingTime}
              </span>
              <span>·</span>
              <ViewCounter client:load slug={`blog/${post.id}`} />
            </div>
          </header>

          <!-- Thumbnail -->
          {post.data.thumbnail && (
            <div class="mb-8 rounded-xl overflow-hidden">
              <img
                src={post.data.thumbnail}
                alt={post.data.title}
                class="w-full h-auto"
              />
            </div>
          )}

          <!-- Content -->
          <div class="prose prose-lg prose-invert max-w-none prose-headings:scroll-mt-20 prose-code:before:content-none prose-code:after:content-none prose-pre:relative prose-pre:p-0">
            <Content />
          </div>

          <!-- Footer: Like, Share, Author Bio -->
          <footer class="mt-16 pt-8 border-t border-zinc-700/50">
            <!-- Like + Share row -->
            <div class="flex flex-wrap items-center justify-between gap-4 mb-10">
              <LikeButton client:load slug={`blog/${post.id}`} label="Like" />
              <ShareButtons title={post.data.title} url={url} />
            </div>

            <!-- Author Bio -->
            <div class="glass rounded-2xl p-6 mb-10">
              <div class="flex items-start gap-4">
                <div class="w-14 h-14 rounded-full bg-zinc-700 flex items-center justify-center text-lg font-bold text-[var(--text-primary)] flex-shrink-0">
                  KB
                </div>
                <div class="flex-1">
                  <h4 class="text-lg font-semibold text-[var(--text-primary)] mb-1">Kaustubh Butte</h4>
                  <p class="text-sm text-[var(--text-muted)] mb-3">
                    Senior Software Engineer at Uber. Building distributed systems at scale. Writes about systems design, algorithms, and engineering culture.
                  </p>
                  <div class="flex items-center gap-3">
                    <a href="https://github.com/kaustubhbutte777" target="_blank" rel="noopener noreferrer"
                       class="text-[var(--text-muted)] hover:text-[var(--text-primary)] transition-colors">
                      <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
                        <path fill-rule="evenodd" d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" clip-rule="evenodd" />
                      </svg>
                    </a>
                    <a href="https://linkedin.com/in/kaustubh-butte" target="_blank" rel="noopener noreferrer"
                       class="text-[var(--text-muted)] hover:text-[var(--text-primary)] transition-colors">
                      <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
                        <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
                      </svg>
                    </a>
                    <a href="https://twitter.com/KaustubhButte" target="_blank" rel="noopener noreferrer"
                       class="text-[var(--text-muted)] hover:text-[var(--text-primary)] transition-colors">
                      <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
                        <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
                      </svg>
                    </a>
                  </div>
                </div>
              </div>
            </div>

            <!-- Previous / Next Navigation -->
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
              {prevPost ? (
                <a href={`/blog/${prevPost.slug}`} class="group glass rounded-xl p-4 hover:bg-[var(--glass-bg-hover)] transition-colors">
                  <span class="text-xs text-[var(--text-muted)] uppercase tracking-wider">Previous</span>
                  <p class="text-sm font-medium text-[var(--text-primary)] mt-1 group-hover:text-emerald-400 transition-colors line-clamp-2">
                    {prevPost.data.title}
                  </p>
                </a>
              ) : <div />}
              {nextPost ? (
                <a href={`/blog/${nextPost.slug}`} class="group glass rounded-xl p-4 hover:bg-[var(--glass-bg-hover)] transition-colors text-right">
                  <span class="text-xs text-[var(--text-muted)] uppercase tracking-wider">Next</span>
                  <p class="text-sm font-medium text-[var(--text-primary)] mt-1 group-hover:text-emerald-400 transition-colors line-clamp-2">
                    {nextPost.data.title}
                  </p>
                </a>
              ) : <div />}
            </div>
          </footer>
        </div>

        <!-- Sidebar -->
        <aside class="hidden lg:block lg:w-72 lg:flex-shrink-0">
          <div class="sticky top-24 space-y-4">
            {headings.length > 0 && (
              <TableOfContents client:load headings={headings} />
            )}

            <div class="glass rounded-xl p-4">
              <LikeButton client:load slug={`blog/${post.id}`} label="Like this post" />
            </div>

            <div class="glass rounded-xl p-4">
              <h3 class="text-sm font-semibold text-[var(--text-primary)] mb-3">Quick Links</h3>
              <div class="space-y-2 text-sm">
                <a href="/blog/archive" class="block text-[var(--text-muted)] hover:text-emerald-400 transition-colors">
                  Archive
                </a>
                <a href="/blog/tags" class="block text-[var(--text-muted)] hover:text-emerald-400 transition-colors">
                  All Tags
                </a>
              </div>
            </div>
          </div>
        </aside>
      </div>
    </div>
  </article>
</BaseLayout>

<style is:global>
  /* Code block copy button styles */
  .prose pre {
    position: relative;
    padding: 1rem;
    padding-top: 2.5rem;
  }

  .prose pre::before {
    content: attr(data-language);
    position: absolute;
    top: 0;
    left: 0;
    padding: 0.25rem 0.75rem;
    font-size: 0.75rem;
    color: #a1a1aa;
    background: rgba(0, 0, 0, 0.3);
    border-radius: 0 0 0.5rem 0;
  }

  .prose pre code {
    display: block;
    overflow-x: auto;
  }

  .copy-button {
    position: absolute;
    top: 0.5rem;
    right: 0.5rem;
    padding: 0.5rem;
    border-radius: 0.5rem;
    background: rgba(63, 63, 70, 0.5);
    color: #a1a1aa;
    cursor: pointer;
    transition: all 0.2s;
  }

  .copy-button:hover {
    background: rgba(63, 63, 70, 0.8);
    color: #e4e4e7;
  }

  /* Heading anchors */
  .prose h2,
  .prose h3,
  .prose h4 {
    position: relative;
  }

  .prose h2:hover .anchor-link,
  .prose h3:hover .anchor-link,
  .prose h4:hover .anchor-link {
    opacity: 1;
  }

  .anchor-link {
    position: absolute;
    left: -1.5rem;
    opacity: 0;
    color: #71717a;
    transition: opacity 0.2s;
  }

  .anchor-link:hover {
    color: #34d399;
  }

  /* Line clamp utility */
  .line-clamp-2 {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>

<script>
  // Add copy buttons to code blocks
  document.querySelectorAll('pre').forEach((pre) => {
    const code = pre.querySelector('code');
    if (!code) return;

    const button = document.createElement('button');
    button.className = 'copy-button';
    button.innerHTML = `<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
      <rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect>
      <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path>
    </svg>`;

    button.addEventListener('click', async () => {
      await navigator.clipboard.writeText(code.textContent || '');
      button.innerHTML = `<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#34d399" stroke-width="2">
        <polyline points="20,6 9,17 4,12"></polyline>
      </svg>`;
      setTimeout(() => {
        button.innerHTML = `<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect>
          <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path>
        </svg>`;
      }, 2000);
    });

    pre.appendChild(button);
  });
</script>
